# Copy this file to .env and fill in your credentials
# DO NOT commit the .env file

# Claude Code OAuth token (from claude.ai subscription)
# Run: claude auth token  — to retrieve your token
CLAUDE_CODE_OAUTH_TOKEN=...

# GitHub personal access token (from https://github.com/settings/tokens)
# Needs 'repo' scope for pushing code and creating PRs
GH_TOKEN=ghp_...
